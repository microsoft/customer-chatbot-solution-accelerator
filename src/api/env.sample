# Azure Cosmos DB (optional - will use mock data if not provided)
COSMOS_DB_ENDPOINT=your_cosmos_db_endpoint
COSMOS_DB_KEY=your_cosmos_db_key
COSMOS_DB_DATABASE_NAME=ecommerce_db

# Azure OpenAI (optional - will use fallback responses if not provided)
AZURE_OPENAI_ENDPOINT=your_openai_endpoint
AZURE_OPENAI_API_KEY=your_openai_api_key
AZURE_OPENAI_API_VERSION=2024-02-15-preview

# Microsoft Entra ID (optional - for future authentication)
AZURE_CLIENT_ID=your_client_id
AZURE_CLIENT_SECRET=your_client_secret
AZURE_TENANT_ID=your_tenant_id

# voice agent config
AZURE_VOICELIVE_ENDPOINT=
AZURE_VOICELIVE_API_KEY=""
VOICELIVE_MODE=model
AZURE_VOICELIVE_AGENT_NAME=your-agent-name
AZURE_VOICELIVE_PROJECT=your-project-name
VOICELIVE_MODEL=gpt-realtime-mini
VOICELIVE_VOICE=en-US-Ava:DragonHDLatestNeural
# VOICELIVE_VOICE=alloy
VOICELIVE_TRANSCRIBE_MODEL=gpt-4o-transcribe
VOICELIVE_INSTRUCTIONS="You are a helpful AI assistant. Respond naturally and conversationally. Keep your responses concise but engaging."
VOICELIVE_VAD_SILENCE_MS=1200
VOICELIVE_VAD_THRESHOLD=0.5
VOICELIVE_VAD_PREFIX_PADDING_MS=300